
# ─────────────────────────────────────────────────────────────
#  PhishGuard RAG Chatbot — Environment Config (LangChain v2)
# ─────────────────────────────────────────────────────────────

# ── Groq API ──────────────────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# LLM Model Selection
# llama-3.1-8b-instant  → Fastest  [default]
# llama-3.3-70b-versatile → Balanced
# openai/gpt-oss-120b   → Strong reasoning
GROQ_MODEL=llama-3.1-8b-instant

# ── RAG Settings ─────────────────────────────────────────────
CHROMA_PATH=./data/processed
TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── LangSmith Tracing (optional) ─────────────────────────────
# Get key at: https://smith.langchain.com
# LANGSMITH_API_KEY=your_langsmith_key_here
# LANGSMITH_PROJECT=phishguard-rag
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
