OLLAMA_BASE_URL=http://localhost:11434
PRIMARY_MODEL=llama3.1:8b
FAST_MODEL=phi3:mini
DB_PATH=./data/phishguard.db
SAFE_BROWSING_KEY=
PORT=8000

# Thresholds (0-100)
THRESHOLD_SAFE=25
THRESHOLD_SUSPICIOUS=55

# Feature flags
USE_SANDBOX=false
USE_SAFE_BROWSING=false
USE_CLUSTERING=true

# Attachment deep-scan size cap (MB). Files larger than this are scored on
# metadata only (filename, extension, MIME type) without downloading content.
# Keep this reasonable — large files are base64-encoded in the request body.
MAX_ATTACHMENT_MB=5
